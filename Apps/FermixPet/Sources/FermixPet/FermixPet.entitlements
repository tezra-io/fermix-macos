<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- The one entitlement the pet needs. Under the hardened runtime (required
       for notarization) the microphone is hard-denied without this, even with
       NSMicrophoneUsageDescription present. The AF_UNIX daemon socket is
       unrestricted under the hardened runtime, so no network/socket entitlement
       is needed. get-task-allow is deliberately absent (release builds only). -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
