<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>io.tezra.FermixPet</string>
  <!-- Display name unified to "Fermix" so the Microphone privacy entry reads the
       same as the computer-use Screen Recording / Accessibility entries. Bundle id
       stays io.tezra.FermixPet (a rename would orphan the existing mic grant). -->
  <key>CFBundleName</key>
  <string>Fermix</string>
  <key>CFBundleIconFile</key>
  <string>FermixPet.icns</string>
  <key>NSMicrophoneUsageDescription</key>
  <string>FermixPet uses microphone input only while you explicitly start a voice call.</string>
</dict>
</plist>
